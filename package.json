{
  "name": "translate2anki",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "test": "jest",
    "test:api": "ts-node scripts/test-api.ts",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.translate2anki.app",
    "productName": "Translate2Anki",
    "forceCodeSigning": false,
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": ["portable"],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "description": "Lightweight desktop translator + AI sentence analyzer with one-click Anki card generation",
  "author": "yukonsun",
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^17.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.3"
  }
}
