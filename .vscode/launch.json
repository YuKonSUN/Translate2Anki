{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron: Main Process",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd",
      "args": [".", "--remote-debugging-port=9223"],
      "cwd": "${workspaceFolder}",
      "outputCapture": "std",
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "build",
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Electron: Renderer Process",
      "type": "chrome",
      "request": "attach",
      "port": 9223,
      "urlFilter": "*",
      "webRoot": "${workspaceFolder}/src",
      "timeout": 10000
    },
    {
      "name": "Electron: Attach to Renderer (port 9222)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "urlFilter": "*",
      "webRoot": "${workspaceFolder}/src"
    }
  ],
  "compounds": [
    {
      "name": "Electron: Main + Renderer",
      "configurations": ["Electron: Main Process", "Electron: Renderer Process"],
      "stopAll": true
    }
  ]
}
